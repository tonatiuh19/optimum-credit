# ─────────────────────────────────────────────────────────────────────────────
# Optimum Credit — Environment Variables Reference
# Copy this file to .env and fill in real values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
# Full public URL of the app (no trailing slash). Used in email links.
PUBLIC_APP_URL=https://yourdomain.com

# ── JWT ──────────────────────────────────────────────────────────────────────
# Long random string used to sign auth tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_random_64_chars

# ── Database (TiDB Cloud Serverless / MySQL 8.0) ─────────────────────────────
DB_HOST=gateway01.us-east-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=optimum_credit
DB_SSL=true

# ── Email — Resend ────────────────────────────────────────────────────────────
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
SMTP_FROM=Optimum Credit <no-reply@yourdomain.com>

# ── Payments — Authorize.net ─────────────────────────────────────────────────
AUTHORIZENET_API_LOGIN_ID=your_login_id
AUTHORIZENET_TRANSACTION_KEY=your_transaction_key
# Set to "true" for sandbox, "false" for production
AUTHORIZENET_SANDBOX=true

# ── Authorize.net (Vite client-side — safe to expose) ────────────────────────
VITE_AUTHORIZENET_API_LOGIN_ID=your_login_id
VITE_AUTHORIZENET_CLIENT_KEY=your_client_key
VITE_AUTHORIZENET_SANDBOX=true

# ── Twilio (SMS — optional) ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+15005550006

# ── Document Encryption ───────────────────────────────────────────────────────
# 32-byte hex key for AES-256 document encryption. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DOC_ENCRYPTION_KEY=change_me_64_hex_chars

# ── Cron Job (notification queue processor) ───────────────────────────────────
# Secret token that cPanel's curl cron must send in the x-cron-secret header.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Endpoint: POST /api/cron/process-queue
CRON_SECRET=change_me_random_64_hex_chars

# ── Vite / Builder (optional) ─────────────────────────────────────────────────
VITE_PUBLIC_BUILDER_KEY=
